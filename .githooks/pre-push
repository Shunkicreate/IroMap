#!/usr/bin/env bash
set -euo pipefail

. "$(git rev-parse --show-toplevel)/.githooks/guard-worktree-and-branch.sh"
require_worktree_checkout
require_feature_branch

while read -r local_ref local_sha remote_ref remote_sha; do
  if [[ "$local_ref" == "refs/heads/main" || "$remote_ref" == "refs/heads/main" ]]; then
    echo "ERROR: main への直接 push は禁止されています。" >&2
    exit 1
  fi
done

cd "$(git rev-parse --show-toplevel)/web"
pnpm run lint
pnpm run format:check
pnpm run test:e2e
