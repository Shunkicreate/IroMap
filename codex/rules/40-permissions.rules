"""IroMap command approval policy.

Goal:
- allow: read-only inspection commands
- prompt: state-changing git/gh commands
- forbidden: destructive commands
"""

REPO_ROOT = "/Users/shunki.tada/VSCode/IroMap"

WORKTREE_PATHS = [
    REPO_ROOT,
    REPO_ROOT + "/.worktree/feature-git-hygiene-iac",
    REPO_ROOT + "/.worktree/rewrite-remove-node-modules-state",
    REPO_ROOT + "/.worktree/shadcn-ui-migration",
    REPO_ROOT + "/.worktree/skill-git-worktree-setup",
    REPO_ROOT + "/.worktree/workbench-initial-implementation",
]

READONLY_GIT_SUBCOMMANDS = [
    "status",
    "diff",
    "log",
    "show",
    "rev-parse",
    "branch",
    "remote",
    "config",
]

# Read-only commands in current directory
prefix_rule(
    pattern=["git", READONLY_GIT_SUBCOMMANDS],
    decision="allow",
)

# Read-only commands with repository/worktree -C operation
prefix_rule(
    pattern=["git", "-C", WORKTREE_PATHS, READONLY_GIT_SUBCOMMANDS],
    decision="allow",
)

prefix_rule(
    pattern=["gh", "auth", "status"],
    decision="allow",
)

prefix_rule(
    pattern=["gh", "pr", "view"],
    decision="allow",
)

# State-changing git commands
prefix_rule(
    pattern=["git", ["add", "restore", "switch", "checkout", "commit", "push", "pull", "fetch", "merge", "rebase", "cherry-pick", "worktree"]],
    decision="prompt",
    justification="Repository state changes require explicit confirmation.",
)

prefix_rule(
    pattern=["git", "-C", WORKTREE_PATHS, ["add", "restore", "switch", "checkout", "commit", "push", "pull", "fetch", "merge", "rebase", "cherry-pick", "worktree"]],
    decision="prompt",
    justification="Worktree operations should stay explicit and auditable.",
)

# PR publishing and updates
prefix_rule(
    pattern=["gh", "pr", ["create", "edit", "reopen", "ready", "close", "merge"]],
    decision="prompt",
    justification="PR state changes should be confirmed case by case.",
)

# Explicitly block destructive git commands
prefix_rule(
    pattern=["git", "reset", "--hard"],
    decision="forbidden",
    justification="Hard reset discards working tree and index state.",
)

prefix_rule(
    pattern=["git", "clean", "-fd"],
    decision="forbidden",
    justification="git clean -fd irreversibly removes untracked files.",
)
