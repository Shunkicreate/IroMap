"""IroMap command approval policy.

Goal:
- allow: read-only inspection commands
- prompt: state-changing git/gh commands
- forbidden: destructive commands
"""

REPO_ROOT = "/Users/shunki.tada/VSCode/IroMap"

READONLY_GIT_SUBCOMMANDS = [
    "status",
    "diff",
    "log",
    "show",
    "rev-parse",
    "branch",
    "remote",
    "config",
]

# Read-only commands in current directory
prefix_rule(
    pattern=["git", READONLY_GIT_SUBCOMMANDS],
    decision="allow",
)

prefix_rule(
    pattern=["gh", "auth", "status"],
    decision="allow",
)

prefix_rule(
    pattern=["gh", "pr", "view"],
    decision="allow",
)

# Read-only quality checks with pnpm
prefix_rule(
    pattern=["pnpm", "--dir", "web", "run", ["lint", "format:check", "setup:hooks:check"]],
    decision="allow",
)

prefix_rule(
    pattern=["pnpm", "run", "worktree:add"],
    decision="allow",
)

prefix_rule(
    pattern=["pnpm", ["-v", "--version"]],
    decision="allow",
)

# State-changing git commands
prefix_rule(
    pattern=["git", ["add", "commit"]],
    decision="allow",
)

prefix_rule(
    pattern=["git", ["restore", "switch", "checkout", "push", "pull", "fetch", "merge", "rebase", "cherry-pick", "worktree"]],
    decision="prompt",
    justification="Repository state changes require explicit confirmation.",
)

prefix_rule(
    pattern=["git", "-C"],
    decision="allow",
)

# PR publishing and updates
prefix_rule(
    pattern=["gh", "pr", "create"],
    decision="allow",
)

prefix_rule(
    pattern=["gh", "pr", ["edit", "reopen", "ready", "close", "merge"]],
    decision="prompt",
    justification="PR state changes should be confirmed case by case.",
)

# pnpm commands
prefix_rule(
    pattern=["pnpm"],
    decision="allow",
)

# Explicitly block destructive git commands
prefix_rule(
    pattern=["git", "reset", "--hard"],
    decision="forbidden",
    justification="Hard reset discards working tree and index state.",
)

prefix_rule(
    pattern=["git", "-C", REPO_ROOT, "reset", "--hard"],
    decision="forbidden",
    justification="Hard reset discards working tree and index state.",
)

prefix_rule(
    pattern=["git", "clean", "-fd"],
    decision="forbidden",
    justification="git clean -fd irreversibly removes untracked files.",
)

prefix_rule(
    pattern=["git", "-C", REPO_ROOT, "clean", "-fd"],
    decision="forbidden",
    justification="git clean -fd irreversibly removes untracked files.",
)
